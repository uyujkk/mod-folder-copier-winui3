<Window
    x:Class="ModFolderCopier.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ModFolderCopier.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="集成化mod管理器 v3.0"
    SizeChanged="OnWindowSizeChanged"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource AppPageBackgroundBrush}" KeyDown="OnRootKeyDown" PointerPressed="OnRootGridPointerPressed">
        <Grid Padding="14" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="HeaderTitleTextBlock" FontSize="34" FontWeight="SemiBold" />
                            <Border Style="{StaticResource SoftBadgeBorderStyle}">
                                <TextBlock x:Name="HeaderFrameworkBadgeTextBlock" FontWeight="SemiBold" />
                            </Border>
                            <Border Style="{StaticResource SoftBadgeBorderStyle}">
                                <TextBlock x:Name="HeaderVersionBadgeTextBlock" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="HeaderSubtitleTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                        <TextBlock x:Name="HeaderCaptionTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="PrimaryNavColumn" Width="72" />
                    <ColumnDefinition x:Name="SecondaryNavColumn" Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

            <Border x:Name="PrimaryNavBorder" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="8,12">
                <StackPanel Spacing="10">
                    <StackPanel Visibility="Collapsed" Spacing="4">
                        <TextBlock x:Name="BetaTitleTextBlock" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock x:Name="BetaCaptionTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button x:Name="DashboardNavButton" Click="OnDashboardNavClicked" Style="{StaticResource SecondaryButtonStyle}" MinHeight="42" HorizontalContentAlignment="Center" UseSystemFocusVisuals="False" />
                    <Button x:Name="RepositoryNavButton" Click="OnRepositoryNavClicked" Style="{StaticResource SecondaryButtonStyle}" MinHeight="42" HorizontalContentAlignment="Center" UseSystemFocusVisuals="False" />
                    <Button x:Name="OnlineNavButton" Click="OnOnlineNavClicked" Style="{StaticResource SecondaryButtonStyle}" MinHeight="42" HorizontalContentAlignment="Center" UseSystemFocusVisuals="False" />
                    <Button x:Name="UpdatesNavButton" Click="OnUpdatesNavClicked" Style="{StaticResource SecondaryButtonStyle}" MinHeight="42" HorizontalContentAlignment="Center" UseSystemFocusVisuals="False" />
                    <Button x:Name="SettingsNavButton" Click="OnSettingsNavClicked" Style="{StaticResource SecondaryButtonStyle}" MinHeight="42" HorizontalContentAlignment="Center" UseSystemFocusVisuals="False" />
                </StackPanel>
            </Border>

            <Border x:Name="SecondaryNavBorder" Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="14">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="SecondaryNavTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" TextWrapping="Wrap" />
                        <TextBlock x:Name="SecondaryNavHintTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SecondaryNavPanel" Spacing="8" />
                    </ScrollViewer>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                            <Button
                                x:Name="AddRepositoryButton"
                                Click="OnAddRepositoryDetailsClicked"
                                Height="42"
                                Style="{StaticResource SecondaryButtonStyle}">
                            <FontIcon Glyph="&#xE710;" FontSize="16" />
                        </Button>

                            <Button
                                x:Name="RenameRepositoryButton"
                                Grid.Column="1"
                                Click="OnEditRepositoryDetailsClicked"
                                Height="42"
                                Style="{StaticResource SecondaryButtonStyle}">
                            <FontIcon Glyph="&#xE70F;" FontSize="16" />
                        </Button>

                        <Button
                            x:Name="DeleteRepositoryButton"
                            Grid.Column="2"
                            Click="OnDeleteRepositoryClicked"
                            Height="42"
                            Style="{StaticResource SecondaryButtonStyle}">
                            <FontIcon Glyph="&#xE74D;" FontSize="16" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <ScrollViewer x:Name="DashboardScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Margin="2" Spacing="14">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock x:Name="DashboardTitleTextBlock" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock x:Name="DashboardSubtitleTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="DashboardRepoCountLabelTextBlock" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock x:Name="DashboardRepoCountTextBlock" Style="{StaticResource MetricValueTextStyle}" Text="0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="DashboardModCountLabelTextBlock" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock x:Name="DashboardModCountTextBlock" Style="{StaticResource MetricValueTextStyle}" Text="0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="DashboardReadyCountLabelTextBlock" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock x:Name="DashboardReadyCountTextBlock" Style="{StaticResource MetricValueTextStyle}" Text="0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock x:Name="DashboardRepositoriesTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                                <StackPanel x:Name="DashboardRepositoriesPanel" Spacing="10" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="WorkspaceScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,16,16" Spacing="14">
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="PathSectionTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock x:Name="PathSectionSubtitleTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="132" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="172" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SourceLabelTextBlock" VerticalAlignment="Center" />
                            <Border Grid.Column="1" Style="{StaticResource InsetBorderStyle}">
                                <TextBox x:Name="SourceTextBox" Padding="12,8" BorderThickness="0" />
                            </Border>
                            <Button x:Name="PickSourceButton" Grid.Column="2" Click="OnPickSourceClicked" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="OpenSourceButton" Grid.Column="3" Click="OnOpenSourceClicked" Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="2" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="132" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="172" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TargetLabelTextBlock" VerticalAlignment="Center" />
                            <Border Grid.Column="1" Style="{StaticResource InsetBorderStyle}">
                                <TextBox x:Name="TargetTextBox" Padding="12,8" BorderThickness="0" />
                            </Border>
                            <Button x:Name="PickTargetButton" Grid.Column="2" Click="OnPickTargetClicked" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="OpenTargetButton" Grid.Column="3" Click="OnOpenTargetClicked" Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="3" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="132" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="172" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LauncherLabelTextBlock" VerticalAlignment="Center" />
                            <Border Grid.Column="1" Style="{StaticResource InsetBorderStyle}">
                                <TextBox x:Name="LauncherTextBox" Padding="12,8" BorderThickness="0" />
                            </Border>
                            <Button x:Name="PickLauncherButton" Grid.Column="2" Click="OnPickLauncherClicked" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="OpenLauncherButton" Grid.Column="3" Click="OnOpenLauncherClicked" Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>

                        <TextBlock
                            x:Name="PathHintTextBlock"
                            Grid.Row="4"
                            Style="{StaticResource MutedTextStyle}"
                            TextWrapping="Wrap" />

                        <Grid Grid.Row="5" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="8" VerticalAlignment="Center">
                                <ProgressBar x:Name="CopyProgressBar" Minimum="0" Maximum="100" Height="8" />
                                <TextBlock x:Name="ProgressTextBlock" Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                            <Button x:Name="RefreshButton" Grid.Column="1" Click="OnRefreshClicked" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="ImportZipButton" Grid.Column="2" Click="OnImportZipClicked" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="RunLauncherButton" Grid.Column="3" Click="OnRunLauncherClicked" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="ToggleCopyButton" Grid.Column="4" Click="OnToggleCopyClicked" Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*" MinWidth="220" />
                                <ColumnDefinition Width="1.1*" MinWidth="220" />
                                <ColumnDefinition Width="1.15*" MinWidth="240" />
                                <ColumnDefinition Width="1.05*" MinWidth="220" />
                            </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="FirstCountLabelTextBlock" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock x:Name="FirstCountTextBlock" Style="{StaticResource MetricValueTextStyle}" Text="0" />
                            <TextBlock x:Name="FirstCountHintTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="SecondCountLabelTextBlock" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock x:Name="SecondCountTextBlock" Style="{StaticResource MetricValueTextStyle}" Text="0" />
                            <TextBlock x:Name="SecondCountHintTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="CurrentStateLabelTextBlock" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock x:Name="CurrentStateTextBlock" Style="{StaticResource MetricValueTextStyle}" />
                            <TextBlock x:Name="CurrentStateHintTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="CurrentFolderLabelTextBlock" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock x:Name="CurrentFolderTextBlock" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock x:Name="CurrentFolderHintTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" MinWidth="280" />
                        <ColumnDefinition Width="1.1*" MinWidth="320" />
                        <ColumnDefinition Width="1.15*" MinWidth="300" />
                        <ColumnDefinition Width="1.05*" MinWidth="260" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="FirstLevelSectionTitleTextBlock" VerticalAlignment="Center" Style="{StaticResource SectionTitleTextStyle}" />
                                <Button
                                    x:Name="CreateFirstLevelButton"
                                    Grid.Column="1"
                                    Width="42"
                                    Height="42"
                                    Padding="0"
                                    Click="OnCreateFirstLevelClicked"
                                    Style="{StaticResource SecondaryButtonStyle}">
                                    <FontIcon FontSize="16" Glyph="&#xE710;" />
                                </Button>
                                <Button
                                    x:Name="RenameFirstLevelButton"
                                    Grid.Column="2"
                                    Width="42"
                                    Height="42"
                                    Padding="0"
                                    Click="OnRenameFirstLevelClicked"
                                    Style="{StaticResource SecondaryButtonStyle}">
                                    <FontIcon FontSize="16" Glyph="&#xE70F;" />
                                </Button>
                            </Grid>
                            <TextBlock x:Name="FirstLevelSectionSubtitleTextBlock" Grid.Row="1" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            <Border Grid.Row="2" Style="{StaticResource InsetBorderStyle}">
                                <TextBox
                                    x:Name="FirstLevelSearchTextBox"
                                    Padding="12,8"
                                    BorderThickness="0"
                                    TextChanged="OnFirstLevelSearchTextChanged" />
                            </Border>
                            <Border Grid.Row="3" Style="{StaticResource InsetBorderStyle}">
                                <ListView x:Name="FirstLevelListView" SelectionChanged="OnFirstLevelSelectionChanged" Style="{StaticResource AppListViewStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:FirstLevelFolderItem">
                                            <Grid Padding="12,10" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Glyph="&#xE8B7;" Opacity="0.75" />
                                                <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                <Border Grid.Column="2" Style="{StaticResource SoftBadgeBorderStyle}">
                                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind ChildrenCount}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SecondLevelSectionTitleTextBlock" VerticalAlignment="Center" Style="{StaticResource SectionTitleTextStyle}" />
                                <Button
                                    x:Name="DeleteSecondLevelButton"
                                    Grid.Column="1"
                                    Width="42"
                                    Height="42"
                                    Padding="0"
                                    Click="OnDeleteSecondLevelClicked"
                                    Style="{StaticResource SecondaryButtonStyle}">
                                    <FontIcon FontSize="16" Glyph="&#xE74D;" />
                                </Button>
                            </Grid>
                            <TextBlock x:Name="SecondLevelSectionSubtitleTextBlock" Grid.Row="1" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            <Border
                                x:Name="SecondLevelDropBorder"
                                Grid.Row="2"
                                AllowDrop="True"
                                Style="{StaticResource InsetBorderStyle}"
                                DragOver="OnSecondLevelDragOver"
                                Drop="OnSecondLevelDrop">
                                <ListView x:Name="SecondLevelListView" SelectionChanged="OnSecondLevelSelectionChanged" DoubleTapped="OnSecondLevelDoubleTapped" Style="{StaticResource AppListViewStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:SecondLevelFolderItem">
                                            <Grid Padding="12,10" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Glyph="&#xEA55;" Opacity="0.75" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontWeight="SemiBold"
                                                    MaxLines="1"
                                                    Text="{x:Bind Name}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    Margin="8,0,0,0"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="{x:Bind State}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="ShortcutSectionTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                            <Grid Grid.Row="1" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="ShortcutSectionSubtitleTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="ShortcutRowsTextBlock" Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                                <Button x:Name="AddShortcutRowButton" Grid.Column="1" Click="OnAddShortcutRowClicked" Style="{StaticResource SecondaryButtonStyle}" />
                            </Grid>
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ShortcutRowsPanel" Spacing="10" />
                            </ScrollViewer>
                            <TextBlock
                                x:Name="ShortcutHintTextBlock"
                                Grid.Row="3"
                                Margin="0,4,0,2"
                                Style="{StaticResource MutedTextStyle}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="PreviewSectionTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock x:Name="PreviewSectionSubtitleTextBlock" Grid.Row="1" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            <Border
                                x:Name="PreviewDropBorder"
                                Grid.Row="2"
                                Height="320"
                                AllowDrop="True"
                                Style="{StaticResource InsetBorderStyle}"
                                Background="{ThemeResource AppPreviewBackgroundBrush}"
                                DragOver="OnPreviewDragOver"
                                Drop="OnPreviewDrop">
                                <Grid>
                                    <Image x:Name="PreviewImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock
                                        x:Name="PreviewHintTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="18"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap"
                                        Style="{StaticResource MutedTextStyle}" />
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="3" Spacing="6">
                                <TextBlock x:Name="ModLinkSectionTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock x:Name="ModLinkSectionSubtitleTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="4" Style="{StaticResource InsetBorderStyle}">
                                <TextBox
                                    x:Name="ModLinkTextBox"
                                    Padding="12,8"
                                    BorderThickness="0"
                                    TextChanged="OnModLinkTextChanged" />
                            </Border>

                            <Grid Grid.Row="5" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PreviewFooterTextBlock" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                <Button
                                    x:Name="OpenModLinkButton"
                                    Grid.Column="1"
                                    Click="OnOpenModLinkClicked"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardBorderStyle}" Padding="14,12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StatusTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                        <TextBlock x:Name="AuthorTextBlock" Grid.Column="1" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="OnlineScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Margin="6" Spacing="16">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock x:Name="OnlineTitleTextBlock" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock x:Name="OnlineSubtitleTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="OnlineRepositoryLabelTextBlock" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock x:Name="OnlineRepositoryValueTextBlock" Style="{StaticResource MetricValueTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="OnlineSourceLabelTextBlock" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock x:Name="OnlineSourceValueTextBlock" Style="{StaticResource MetricValueTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="OnlineReadyLabelTextBlock" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock x:Name="OnlineReadyValueTextBlock" Style="{StaticResource MetricValueTextStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock x:Name="OnlineConfigTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock x:Name="OnlineConfigHintTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="OnlineCategoryLabelTextBlock" VerticalAlignment="Center" />
                                    <TextBlock x:Name="OnlineCategoryValueTextBlock" Grid.Column="1" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="OnlineNotesLabelTextBlock" VerticalAlignment="Top" />
                                    <TextBlock x:Name="OnlineNotesValueTextBlock" Grid.Column="1" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                </Grid>
                                <Button
                                    x:Name="EditOnlineRepositoryButton"
                                    Click="OnEditRepositoryDetailsClicked"
                                    MinHeight="42"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="OnlinePreviewTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" VerticalAlignment="Center" />
                                    <Button
                                        x:Name="RefreshOnlineButton"
                                        Grid.Column="1"
                                        Click="OnRefreshOnlineModsClicked"
                                        MinHeight="40"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                                <TextBlock x:Name="OnlinePreviewHintTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                <TextBlock x:Name="OnlineStatusTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                                <StackPanel x:Name="OnlineDownloadProgressPanel" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="OnlineDownloadProgressTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                                    <ProgressBar x:Name="OnlineDownloadProgressBar" Minimum="0" Maximum="100" Height="8" />
                                </StackPanel>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="520" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="OnlineSearchTextBox"
                                        Grid.Column="0"
                                        MinHeight="40"
                                        MaxWidth="520"
                                        Padding="14,8"
                                        HorizontalAlignment="Left"
                                        PlaceholderText="搜索角色名或 Mod 名称"
                                        TextChanged="OnOnlineSearchTextChanged" />
                                    <ComboBox
                                        x:Name="OnlineCharacterComboBox"
                                        Grid.Column="2"
                                        MinHeight="40"
                                        HorizontalAlignment="Stretch"
                                        SelectionChanged="OnOnlineCharacterSelectionChanged" />
                                    <ComboBox
                                        x:Name="OnlineSortComboBox"
                                        Grid.Column="3"
                                        MinHeight="40"
                                        HorizontalAlignment="Stretch"
                                        SelectionChanged="OnOnlineSortSelectionChanged" />
                                </Grid>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        x:Name="OnlinePrevPageButton"
                                        Click="OnOnlinePrevPageClicked"
                                        MinHeight="36"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                    <TextBlock
                                        x:Name="OnlinePaginationTextBlock"
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource CaptionTextStyle}" />
                                    <Button
                                        x:Name="OnlineNextPageButton"
                                        Grid.Column="2"
                                        Click="OnOnlineNextPageClicked"
                                        MinHeight="36"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                                <StackPanel x:Name="OnlinePreviewPanel" Spacing="10" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="UpdatesScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Margin="6" Spacing="16">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock x:Name="UpdatesTitleTextBlock" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock x:Name="UpdatesSubtitleTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock x:Name="TrackedModSettingsTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock x:Name="TrackedModSettingsHintTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        x:Name="ModUpdateIntervalLabelTextBlock"
                                        VerticalAlignment="Center" />

                                    <ComboBox
                                        x:Name="ModUpdateIntervalComboBox"
                                        Grid.Column="1"
                                        MinHeight="42"
                                        SelectionChanged="OnModUpdateIntervalSelectionChanged" />

                                    <Button
                                        x:Name="CheckModUpdatesButton"
                                        Grid.Column="2"
                                        Click="OnCheckModUpdatesClicked"
                                        MinHeight="42"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                                <TextBlock x:Name="ModUpdateIntervalHintTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                                <TextBlock x:Name="ModUpdateStatusTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock x:Name="TrackedModsTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock x:Name="TrackedModsSummaryTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                <StackPanel x:Name="TrackedModsListPanel" Spacing="10" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SettingsScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Margin="6" Spacing="16">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock x:Name="SettingsTitleTextBlock" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock x:Name="SettingsSubtitleTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock x:Name="SettingsAppearanceTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        x:Name="LanguageToggleButton"
                                        Click="OnLanguageToggleClicked"
                                        MinHeight="42"
                                        Style="{StaticResource SecondaryButtonStyle}" />

                                    <Button
                                        x:Name="ThemeToggleButton"
                                        Grid.Column="1"
                                        Click="OnThemeToggleClicked"
                                        MinHeight="42"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock x:Name="SettingsProjectTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock x:Name="SettingsProjectHintTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        x:Name="UpdateCheckIntervalLabelTextBlock"
                                        VerticalAlignment="Center" />

                                    <ComboBox
                                        x:Name="UpdateCheckIntervalComboBox"
                                        Grid.Column="1"
                                        MinHeight="42"
                                        SelectionChanged="OnUpdateCheckIntervalSelectionChanged"
                                        PlaceholderText="Select update check interval" />
                                </Grid>
                                <TextBlock x:Name="UpdateCheckIntervalHintTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        x:Name="OpenGitHubButton"
                                        Click="OnOpenGitHubClicked"
                                        MinHeight="42"
                                        Style="{StaticResource SecondaryButtonStyle}" />

                                    <Button
                                        x:Name="CheckUpdatesButton"
                                        Grid.Column="1"
                                        Click="OnCheckUpdatesClicked"
                                        MinHeight="42"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                                <TextBlock x:Name="UpdateStatusTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                                <Border Style="{StaticResource InsetBorderStyle}" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="LatestReleaseTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" TextWrapping="Wrap" />
                                        <TextBlock x:Name="LatestReleaseMetaTextBlock" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                                        <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="UpdateNotesTextBlock" TextWrapping="Wrap" />
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock x:Name="SettingsPlaceholderTitleTextBlock" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock x:Name="SettingsPlaceholderTextBlock" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
        </Grid>
    </Grid>
</Window>
