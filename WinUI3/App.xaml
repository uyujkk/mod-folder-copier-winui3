<Application
    x:Class="ModFolderCopier.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#F5F7FA" />
                    <SolidColorBrush x:Key="AppCardBackgroundBrush" Color="#FBFBFD" />
                    <SolidColorBrush x:Key="AppCardBorderBrush" Color="#D9E1EA" />
                    <SolidColorBrush x:Key="AppInsetBackgroundBrush" Color="#F4F6F8" />
                    <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#E8F1FF" />
                    <SolidColorBrush x:Key="AppPreviewBackgroundBrush" Color="#EEF2F7" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#1B1F27" />
                    <SolidColorBrush x:Key="AppCardBackgroundBrush" Color="#272C35" />
                    <SolidColorBrush x:Key="AppCardBorderBrush" Color="#414A57" />
                    <SolidColorBrush x:Key="AppInsetBackgroundBrush" Color="#323844" />
                    <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#21324D" />
                    <SolidColorBrush x:Key="AppPreviewBackgroundBrush" Color="#20252E" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource AppCardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource AppCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <Style x:Key="InsetBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource AppInsetBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource AppCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
            </Style>

            <Style x:Key="SoftBadgeBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource AppAccentSoftBrush}" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="MutedTextStyle" TargetType="TextBlock">
                <Setter Property="Opacity" Value="0.74" />
            </Style>

            <Style x:Key="CaptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="34" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="#2563EB" />
                <Setter Property="BorderBrush" Value="#2563EB" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="MinHeight" Value="40" />
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource AppInsetBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource AppCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16,10" />
                <Setter Property="MinHeight" Value="40" />
            </Style>

            <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                <Setter Property="Padding" Value="18" />
            </Style>

            <Style x:Key="AppListViewStyle" TargetType="ListView">
                <Setter Property="Padding" Value="6" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="SelectionMode" Value="Single" />
                <Setter Property="IsItemClickEnabled" Value="False" />
            </Style>

            <Style x:Key="ShortcutInputTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="Padding" Value="10,8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
