<Window
    x:Class="ModFolderCopier.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ModFolderCopier.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Mod 文件复制器 v2.2"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource AppPageBackgroundBrush}" KeyDown="OnRootKeyDown">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" Spacing="18">
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Mod 文件复制器" FontSize="34" FontWeight="SemiBold" />
                                <Border Style="{StaticResource SoftBadgeBorderStyle}">
                                    <TextBlock Text="WinUI 3" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource SoftBadgeBorderStyle}">
                                    <TextBlock Text="v2.2" FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                            <TextBlock
                                x:Name="HeaderSubtitleText"
                                Style="{StaticResource MutedTextStyle}"
                                Text="保留两级目录、预览图、复制切换、ZIP 导入和按 Mod 保存的快捷键绑定。" />
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="左侧选择第一层分类，再选择第二层 Mod。双击第二层可直接复制或移除。" />
                        </StackPanel>

                        <Button
                            x:Name="ThemeToggleButton"
                            Grid.Column="1"
                            MinWidth="140"
                            Height="40"
                            VerticalAlignment="Top"
                            Click="OnThemeToggleClicked"
                            Content="切换深色"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="6">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="路径小模块" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="主文件夹、副文件夹和 XXMI 启动器都集中在这里管理。" />
                        </StackPanel>

                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="148" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="主文件夹" />
                            <Border Grid.Column="1" Style="{StaticResource InsetBorderStyle}">
                                <TextBox x:Name="SourceTextBox" Padding="12,8" BorderThickness="0" />
                            </Border>
                            <Button Grid.Column="2" Click="OnPickSourceClicked" Content="选择" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="3" Click="OnOpenSourceClicked" Content="打开主文件夹" Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="2" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="148" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="副文件夹" />
                            <Border Grid.Column="1" Style="{StaticResource InsetBorderStyle}">
                                <TextBox x:Name="TargetTextBox" Padding="12,8" BorderThickness="0" />
                            </Border>
                            <Button Grid.Column="2" Click="OnPickTargetClicked" Content="选择" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="3" Click="OnOpenTargetClicked" Content="打开副文件夹" Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="3" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="148" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="启动器" />
                            <Border Grid.Column="1" Style="{StaticResource InsetBorderStyle}">
                                <TextBox x:Name="LauncherTextBox" Padding="12,8" BorderThickness="0" PlaceholderText="选择 XXMI 启动器 EXE" />
                            </Border>
                            <Button Grid.Column="2" Click="OnPickLauncherClicked" Content="选择程序" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="3" Click="OnOpenLauncherClicked" Content="打开启动器位置" Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>

                        <TextBlock
                            Grid.Row="4"
                            Style="{StaticResource MutedTextStyle}"
                            Text="支持刷新目录、导入 ZIP、复制当前第二层文件夹，也可以直接运行 XXMI 启动器。" />

                        <Grid Grid.Row="5" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="8" VerticalAlignment="Center">
                                <ProgressBar x:Name="CopyProgressBar" Minimum="0" Maximum="100" Height="8" />
                                <TextBlock x:Name="ProgressTextBlock" Style="{StaticResource MutedTextStyle}" Text="当前无复制任务" />
                            </StackPanel>
                            <Button Grid.Column="1" Click="OnRefreshClicked" Content="刷新目录" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="2" Click="OnImportZipClicked" Content="导入 ZIP 到当前第二层" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="3" Click="OnRunLauncherClicked" Content="运行 XXMI 启动器" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="4" Click="OnToggleCopyClicked" Content="复制当前第二层文件夹" Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource MutedTextStyle}" Text="第一层目录数" />
                            <TextBlock x:Name="FirstCountTextBlock" Style="{StaticResource MetricValueTextStyle}" Text="0" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="当前主目录下的分类数量" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource MutedTextStyle}" Text="第二层目录数" />
                            <TextBlock x:Name="SecondCountTextBlock" Style="{StaticResource MetricValueTextStyle}" Text="0" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="当前扫描到的 Mod 总数" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource MutedTextStyle}" Text="当前复制状态" />
                            <TextBlock x:Name="CurrentStateTextBlock" Style="{StaticResource MetricValueTextStyle}" Text="未选择" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="根据副文件夹中的同名目录判断" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource MutedTextStyle}" Text="当前第二层文件夹" />
                            <TextBlock x:Name="CurrentFolderTextBlock" FontSize="22" FontWeight="SemiBold" Text="未选择" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="这里会显示当前选中的 Mod 名称" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="第一层文件夹" />
                            <TextBlock Grid.Row="1" Style="{StaticResource MutedTextStyle}" Text="先选择分类目录" />
                            <Border Grid.Row="2" Style="{StaticResource InsetBorderStyle}">
                                <ListView x:Name="FirstLevelListView" SelectionChanged="OnFirstLevelSelectionChanged" Style="{StaticResource AppListViewStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:FirstLevelFolderItem">
                                            <Grid Padding="12,10" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Glyph="&#xE8B7;" Opacity="0.75" />
                                                <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                <Border Grid.Column="2" Style="{StaticResource SoftBadgeBorderStyle}">
                                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{x:Bind ChildrenCount}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="第二层文件夹" />
                            <TextBlock Grid.Row="1" Style="{StaticResource MutedTextStyle}" Text="再选择具体 Mod" />
                            <Border Grid.Row="2" Style="{StaticResource InsetBorderStyle}">
                                <ListView x:Name="SecondLevelListView" SelectionChanged="OnSecondLevelSelectionChanged" DoubleTapped="OnSecondLevelDoubleTapped" Style="{StaticResource AppListViewStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:SecondLevelFolderItem">
                                            <Grid Padding="12,10" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="86" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Glyph="&#xEA55;" Opacity="0.75" />
                                                <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                <TextBlock Grid.Column="2" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Text="{x:Bind FilesCount}" />
                                                <TextBlock Grid.Column="3" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Text="{x:Bind State}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="快捷键与功能" />
                            <Grid Grid.Row="1" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="当前选中 Mod 的快捷键绑定" />
                                    <TextBlock x:Name="ShortcutRowsTextBlock" Style="{StaticResource MutedTextStyle}" Text="当前 1 / 10 行" />
                                </StackPanel>
                                <Button Grid.Column="1" Click="OnAddShortcutRowClicked" Content="新增一行" Style="{StaticResource SecondaryButtonStyle}" />
                            </Grid>
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ShortcutRowsPanel" Spacing="10" />
                            </ScrollViewer>
                            <TextBlock
                                Grid.Row="3"
                                Style="{StaticResource MutedTextStyle}"
                                Text="当前窗口聚焦时，按下填写的快捷键会定位并执行对应 Mod。" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="默认图像预览" />
                            <TextBlock Grid.Row="1" Style="{StaticResource MutedTextStyle}" Text="优先 preview / cover / image，可拖动图片到这里" />
                            <Border
                                x:Name="PreviewDropBorder"
                                Grid.Row="2"
                                AllowDrop="True"
                                Style="{StaticResource InsetBorderStyle}"
                                Background="{ThemeResource AppPreviewBackgroundBrush}"
                                DragOver="OnPreviewDragOver"
                                Drop="OnPreviewDrop">
                                <Grid>
                                    <Image x:Name="PreviewImage" Stretch="Uniform" />
                                    <TextBlock
                                        x:Name="PreviewHintTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        TextAlignment="Center"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="当前第二层文件夹未找到可预览图片&#10;可将图片拖到这里设置为当前 Mod 预览图" />
                                </Grid>
                            </Border>
                            <TextBlock Grid.Row="3" Style="{StaticResource MutedTextStyle}" Text="默认显示当前第二层文件夹中的预览图，也支持直接拖图导入。" />
                        </Grid>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardBorderStyle}" Padding="14,12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StatusTextBlock" Style="{StaticResource MutedTextStyle}" Text="请选择主文件夹和副文件夹。当前版本：v2.2" />
                        <TextBlock Grid.Column="1" Style="{StaticResource CaptionTextStyle}" Text="Author: uyujkk" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
